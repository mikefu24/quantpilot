# 复制为 .env 并填入真实值。.env 不要提交到 git！
# ============ 安全总开关 ============
# 默认不填=DRY_RUN 空跑（只打印不下单）。确认无误后再设为 true 真实交易。
LIVE_TRADING=false

# ============ 大模型 ============
# provider: claude / deepseek / openai / custom
LLM_PROVIDER=claude
LLM_MODEL=claude-sonnet-4-5
LLM_API_KEY=
# 用 DeepSeek 时示例：
#   LLM_PROVIDER=deepseek
#   LLM_MODEL=deepseek-chat
#   LLM_API_KEY=sk-...
#   LLM_BASE_URL=https://api.deepseek.com
# 用 Agnes/本地兼容 OpenAI 协议模型：设 LLM_PROVIDER=custom + LLM_BASE_URL
LLM_BASE_URL=

# ============ 数据监听 ============
NEWS_API_KEY=
TWITTER_BEARER_TOKEN=
POLL_INTERVAL_SEC=5

# ============ Polymarket ============
POLY_CLOB_URL=https://clob.polymarket.com
POLY_PRIVATE_KEY=          # Polygon 钱包私钥（务必保密！）
POLY_API_KEY=              # CLOB L2 凭证（可留空，程序会自动派生）
POLY_API_SECRET=
POLY_API_PASSPHRASE=
POLY_FUNDER=               # 代理钱包地址（用 email/magic 登录时）
TARGET_MARKET_ID=          # 目标事件市场 condition_id / slug

# ============ 风控（可覆盖 config.yaml）============
MAX_SLIPPAGE=0.02
MAX_SPREAD=0.05
MIN_DEPTH_SHARES=50
MAX_POSITION_USD=100
MAX_ORDER_USD=25
MIN_EDGE=0.08
MIN_CONFIDENCE=0.65
COOLDOWN_SEC=60
