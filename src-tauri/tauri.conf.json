{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QuantPilot",
  "version": "1.0.0",
  "identifier": "com.quantpilot.desktop",
  "build": {
    "frontendDist": "../app"
  },
  "app": {
    "windows": [
      {
        "title": "QuantPilot · 智能交易终端",
        "width": 1180,
        "height": 820,
        "minWidth": 860,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "category": "Finance",
    "targets": ["dmg", "app"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.icns", "icons/icon.png"]
  }
}
